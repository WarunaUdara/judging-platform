# Application URL for local development
# use the app URL for production deployment (e.g., https://yourdomain.com) in .env.production or set it via environment variables in your hosting platform (e.g., Vercel, Netlify)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (new migration target)
# Use publishable key from Supabase Project Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Supabase service role key (server-side only, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database Seeding (Optional - for upcoming Supabase seed scripts)
# SEED_SUPERADMIN_UID=
# SEED_SUPERADMIN_EMAIL=your-admin-email@example.com
# SEED_SUPERADMIN_NAME=Your Name
# SEED_SUPERADMIN_PHOTO_URL=
