# Test Environment Variables
# Copy this to .env.test and fill in actual values for testing
# NEVER commit .env.test to version control

# ========================================
# MVP Test User Credentials
# Used by scripts/mvp-seed.ts and e2e/mvp-flow.spec.ts
# ========================================

# Admin account
TEST_ADMIN_EMAIL=admin@cryptx.lk
TEST_ADMIN_PASSWORD=your-secure-password-here

# Primary evaluator account
TEST_EVALUATOR_EMAIL=judge1@cryptx.lk
TEST_EVALUATOR_PASSWORD=your-secure-password-here

# Additional evaluator accounts (use same password as TEST_EVALUATOR_PASSWORD)
TEST_EVALUATOR2_EMAIL=judge2@cryptx.lk
TEST_EVALUATOR3_EMAIL=judge3@cryptx.lk

# ========================================
# Automated Test Credentials
# Used by scripts/automated-test.ts
# ========================================

TEST_ORG_ADMIN_EMAIL=test-admin@test.com
TEST_ORG_ADMIN_PASSWORD=your-secure-password-here
TEST_ORG_EVALUATOR_PASSWORD=your-secure-password-here

# ========================================
# Security Notes
# ========================================
# - Use strong passwords (min 8 chars, mix of letters/numbers/symbols)
# - Do NOT use production passwords in test environment
# - Do NOT commit .env.test file to git (already in .gitignore)
# - Change these passwords regularly
